# Copy this file to .env and fill only the providers you use.
# Do not commit real secrets.

# Required only for live RAGAS generation/evaluation and OpenAI judge mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: use Groq-hosted Prompt Guard 2 for live prompt-injection detection.
GROQ_API_KEY=
GROQ_PROMPT_GUARD_MODEL=meta-llama/llama-prompt-guard-2-22m

# Historical Lab 24 option. Groq marks Llama Guard 3 as deprecated in current docs.
GROQ_LLAMA_GUARD_MODEL=llama-guard-3-8b

# Optional: required if you download gated Hugging Face models.
HUGGINGFACEHUB_API_TOKEN=

# Optional observability for live eval runs.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lab24-eval-guardrails
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Runtime mode: offline works without APIs; live uses external providers.
LAB24_MODE=offline
